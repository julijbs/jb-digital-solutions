{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    { "src": "^/$",                     "dest": "https://jbds-marketing.vercel.app/" },
    { "src": "^/para$",                 "dest": "https://jbds-marketing.vercel.app/para" },
    { "src": "^/para(/.*)",             "dest": "https://jbds-marketing.vercel.app/para$1" },
    { "src": "^/blog$",                 "dest": "https://jbds-marketing.vercel.app/blog" },
    { "src": "^/blog(/.*)",             "dest": "https://jbds-marketing.vercel.app/blog$1" },
    { "src": "^/_astro/(.+)",           "dest": "https://jbds-marketing.vercel.app/_astro/$1" },
    { "src": "^/sitemap-index\\.xml$",  "dest": "https://jbds-marketing.vercel.app/sitemap-index.xml" },
    { "src": "^/sitemap-0\\.xml$",      "dest": "https://jbds-marketing.vercel.app/sitemap-0.xml" },
    { "handle": "filesystem" },
    { "src": "/.*",                     "dest": "/index.html" }
  ]
}
