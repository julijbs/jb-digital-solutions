{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/",                  "destination": "https://jbds-marketing.vercel.app/" },
    { "source": "/para",              "destination": "https://jbds-marketing.vercel.app/para" },
    { "source": "/para/:path*",       "destination": "https://jbds-marketing.vercel.app/para/:path*" },
    { "source": "/blog",              "destination": "https://jbds-marketing.vercel.app/blog" },
    { "source": "/blog/:path*",       "destination": "https://jbds-marketing.vercel.app/blog/:path*" },
    { "source": "/_astro/:path*",     "destination": "https://jbds-marketing.vercel.app/_astro/:path*" },
    { "source": "/sitemap-index.xml", "destination": "https://jbds-marketing.vercel.app/sitemap-index.xml" },
    { "source": "/sitemap-0.xml",     "destination": "https://jbds-marketing.vercel.app/sitemap-0.xml" },
    { "source": "/(.*)",              "destination": "/index.html" }
  ]
}
