---
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/sections/SiteNav.astro';
import SiteFooter from '../../components/sections/SiteFooter.astro';
import FaqB2B from '../../components/sections/FaqB2B.astro';
import RelatedPosts from '../../components/sections/RelatedPosts.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', p => !p.data.draft);
  return posts.map(post => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const canonical = `https://jbdigitalsystem.com/blog/${post.id}/`;

// Related posts: same vertical first, then same cluster — max 3
const allPosts = await getCollection('blog', p => !p.data.draft && p.id !== post.id);
const sameVertical = allPosts.filter(p => p.data.vertical === post.data.vertical);
const sameCluster  = allPosts.filter(p => p.data.cluster === post.data.cluster && p.data.vertical !== post.data.vertical);
const related = [...sameVertical, ...sameCluster]
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const verticalLabels: Record<string,string> = {
  psicologos: 'Psicólogos', dentistas: 'Dentistas',
  nutricionistas: 'Nutricionistas', fisioterapeutas: 'Fisioterapeutas',
};

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": post.data.title,
      "description": post.data.description,
      "datePublished": post.data.pubDate.toISOString(),
      "dateModified": (post.data.updatedDate ?? post.data.pubDate).toISOString(),
      "url": canonical,
      "publisher": {
        "@type": "Organization",
        "name": "JB Digital Consulting",
        "url": "https://jbdigitalsystem.com",
      },
    },
    ...(post.data.faqs ? [{
      "@type": "FAQPage",
      "mainEntity": post.data.faqs.map((f: {q:string;a:string}) => ({
        "@type": "Question", "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a },
      })),
    }] : []),
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "JB Digital", "item": "https://jbdigitalsystem.com/" },
        { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://jbdigitalsystem.com/blog/" },
        { "@type": "ListItem", "position": 3, "name": post.data.title, "item": canonical },
      ],
    },
  ],
};
---
<Layout
  title={post.data.title}
  description={post.data.description}
  canonical={canonical}
  ogType="article"
  schemaJson={JSON.stringify(schema)}
>
  <SiteNav />
  <main id="main">
    <article class="section-wrap post-article">
      <header class="post-header">
        <span class="post-vertical">{verticalLabels[post.data.vertical]}</span>
        <h1>{post.data.title}</h1>
        <time datetime={post.data.pubDate.toISOString()}>
          Publicado em {post.data.pubDate.toLocaleDateString('pt-BR', { day:'2-digit', month:'long', year:'numeric' })}
        </time>
      </header>
      <div class="post-body prose">
        <Content />
      </div>
      <div class="post-cta">
        <p>Quer aplicar isso na sua prática?</p>
        <a href={`/para/${post.data.vertical}/`} class="btn btn-primary">
          Ver o sistema para {verticalLabels[post.data.vertical]} →
        </a>
      </div>
    </article>
    {post.data.faqs && post.data.faqs.length > 0 && (
      <FaqB2B faqs={post.data.faqs} />
    )}
    {related.length > 0 && (
      <RelatedPosts posts={related} />
    )}
  </main>
  <SiteFooter />
</Layout>

<style>
  .post-article { padding: 6rem 0; max-width: 720px; margin: 0 auto; }
  .post-header { margin-bottom: 3rem; }
  .post-vertical {
    display: inline-block; font-size: 0.6875rem; font-weight: 600;
    letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--brand-primary); margin-bottom: 1rem;
  }
  .post-header h1 { font-size: clamp(2rem,4vw,3rem); margin-bottom: 0.75rem; }
  .post-header time { font-size: 0.875rem; color: var(--brand-ink-faint); }
  .post-body { color: var(--brand-ink-muted); line-height: 1.8; }
  .post-body :global(h2) { font-family: var(--brand-font-display); font-size: 1.75rem; color: var(--brand-ink); margin: 2.5rem 0 1rem; }
  .post-body :global(h3) { font-family: var(--brand-font-display); font-size: 1.25rem; color: var(--brand-ink); margin: 2rem 0 0.75rem; }
  .post-body :global(p)  { margin-bottom: 1.25rem; }
  .post-body :global(ul) { padding-left: 1.5rem; margin-bottom: 1.25rem; }
  .post-body :global(li) { margin-bottom: 0.5rem; }
  .post-body :global(strong) { color: var(--brand-ink); }
  .post-cta {
    margin-top: 4rem; padding: 2rem;
    background: var(--brand-surface-alt); border: 1px solid var(--brand-primary);
    border-radius: 0.75rem; text-align: center;
  }
  .post-cta p { margin-bottom: 1.25rem; font-size: 1.0625rem; color: var(--brand-ink); }
</style>
