---
import Layout from '../../layouts/Layout.astro';
import SiteNav from '../../components/sections/SiteNav.astro';
import SiteFooter from '../../components/sections/SiteFooter.astro';
import { getCollection } from 'astro:content';
import { verticals } from '../../data/verticals.ts';

export async function getStaticPaths() {
  return verticals.map(v => ({
    params: { vertical: v.slug },
    props: { vertical: v },
  }));
}

const { vertical } = Astro.props;
const canonical = new URL(`/blog/${vertical.slug}/`, Astro.site).href;

const posts = (await getCollection('blog', p =>
  !p.data.draft && p.data.vertical === vertical.slug
)).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "name": `Blog para ${vertical.professionPlural} — JB Digital System`,
      "description": `Artigos sobre como ${vertical.professionPlural.toLowerCase()} podem atrair mais pacientes organicamente com Google, SEO e presença nas IAs.`,
      "url": canonical,
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "JB Digital", "item": "https://jbdigitalsystem.com/" },
        { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://jbdigitalsystem.com/blog/" },
        { "@type": "ListItem", "position": 3, "name": `Para ${vertical.professionPlural}`, "item": canonical },
      ],
    },
  ],
};
---
<Layout
  title={`Blog para ${vertical.professionPlural} | JB Digital System`}
  description={`Artigos sobre como ${vertical.professionPlural.toLowerCase()} podem atrair mais pacientes organicamente com Google, site e presença nas IAs.`}
  canonical={canonical}
  schemaJson={JSON.stringify(schema)}
>
  <SiteNav />
  <main id="main">
    <section class="section-wrap blog-hero">
      <nav class="breadcrumb" aria-label="Caminho">
        <a href="/">JB Digital</a>
        <span aria-hidden="true">›</span>
        <a href="/blog/">Blog</a>
        <span aria-hidden="true">›</span>
        <span aria-current="page">Para {vertical.professionPlural}</span>
      </nav>
      <h1>Blog para {vertical.professionPlural}</h1>
      <p>
        Como {vertical.professionPlural.toLowerCase()} podem atrair mais pacientes organicamente —
        Google, site, Perfil Google e presença nas IAs.
      </p>
    </section>

    <section class="section-wrap blog-list">
      {posts.length === 0 ? (
        <p class="empty-state">Em breve — novos artigos para {vertical.professionPlural.toLowerCase()} chegando.</p>
      ) : (
        <div class="posts-grid">
          {posts.map(post => (
            <a href={`/blog/${post.id}/`} class="post-card">
              <span class="post-vertical">{vertical.professionPlural}</span>
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('pt-BR')}
              </time>
            </a>
          ))}
        </div>
      )}
    </section>

    <section class="section-wrap vertical-cta">
      <div class="cta-box">
        <p>Quer aplicar isso na sua prática?</p>
        <a href={`/para/${vertical.slug}/`} class="btn btn-primary">
          Ver o sistema para {vertical.professionPlural} →
        </a>
      </div>
    </section>
  </main>
  <SiteFooter />
</Layout>

<style>
  .blog-hero { padding: 7rem 0 2rem; }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--brand-ink-faint);
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }
  .breadcrumb a {
    color: var(--brand-ink-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .breadcrumb a:hover { color: var(--brand-primary); }
  .breadcrumb span[aria-current] { color: var(--brand-ink-faint); }

  .blog-hero h1 { font-size: clamp(1.8rem, 4vw, 3rem); margin-bottom: 0.75rem; }
  .blog-hero p  { color: var(--brand-ink-muted); font-size: 1.0625rem; }

  .blog-list { padding-bottom: 2rem; }
  .empty-state { color: var(--brand-ink-muted); }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
  }

  .post-card {
    display: block;
    background: var(--brand-surface-alt);
    border: 1px solid var(--brand-border);
    border-radius: 0.75rem;
    padding: 1.5rem;
    text-decoration: none;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .post-card:hover { border-color: var(--brand-primary); transform: translateY(-2px); }

  .post-vertical {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--brand-primary);
    margin-bottom: 0.75rem;
  }
  .post-card h2 { font-size: 1.125rem; color: var(--brand-ink); margin-bottom: 0.5rem; line-height: 1.4; }
  .post-card p  { font-size: 0.875rem; color: var(--brand-ink-muted); margin-bottom: 1rem; line-height: 1.6; }
  .post-card time { font-size: 0.8125rem; color: var(--brand-ink-faint); }

  .vertical-cta { padding-bottom: 6rem; }
  .cta-box {
    border: 1px solid var(--brand-primary);
    border-radius: 0.75rem;
    background: var(--brand-surface-alt);
    padding: 2rem;
    text-align: center;
    max-width: 560px;
    margin: 0 auto;
  }
  .cta-box p { color: var(--brand-ink); font-size: 1.0625rem; margin-bottom: 1.25rem; }
</style>
