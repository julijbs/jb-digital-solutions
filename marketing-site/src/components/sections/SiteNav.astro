---
export interface NavItem { label: string; href: string; }

import { whatsappUrl } from '../../data/pricing.ts';

export interface Props {
  currentPath?: string;
  navItems?: NavItem[];
}

const { currentPath = '/', navItems } = Astro.props;
const wUrl = `${whatsappUrl}?text=${encodeURIComponent('Olá! Vim pelo site da JB Digital e quero saber mais.')}`;

const defaultNavLinks: NavItem[] = [
  { label: 'Para quem é', href: '/#para-quem' },
  { label: 'Como funciona', href: '/#como-funciona' },
  { label: 'Planos', href: '/#planos' },
  { label: 'Portfólio', href: '/#portfolio' },
  { label: 'FAQ', href: '/#faq' },
];

const navLinks = navItems ?? defaultNavLinks;
---

<header class="site-nav" id="site-nav">
  <div class="section-wrap nav-inner">
    <a href="/" class="nav-logo" aria-label="JB Digital System — Página inicial">
      <img src="/logo-jb-digital.png" alt="JB Digital" class="nav-logo-img" />
    </a>

    <nav aria-label="Navegação principal">
      <ul class="nav-links" role="list">
        {navLinks.map(link => (
          <li>
            <a href={link.href} class="nav-link">{link.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="nav-cta">
      <a href={wUrl} class="btn btn-primary" target="_blank" rel="noopener">
        Falar agora
      </a>
    </div>
  </div>
</header>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(11, 29, 46, 0.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--brand-border);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding-block: 1rem;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .nav-logo-img {
    height: 2.25rem;
    width: auto;
    display: block;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.75rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    font-family: var(--brand-font-body);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--brand-ink-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .nav-link:hover { color: var(--brand-primary); }

  @media (max-width: 768px) {
    .nav-links { display: none; }
    .nav-cta .btn { font-size: 0.8125rem; padding: 0.5rem 1rem; }
  }
</style>
