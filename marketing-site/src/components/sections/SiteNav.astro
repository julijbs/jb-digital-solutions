---
export interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

const navLinks = [
  { label: 'Para quem é', href: '#para-quem' },
  { label: 'Como funciona', href: '#como-funciona' },
  { label: 'Planos', href: '#planos' },
  { label: 'Portfólio', href: '#portfolio' },
  { label: 'FAQ', href: '#faq' },
];
---

<header class="site-nav" id="site-nav">
  <div class="section-wrap nav-inner">
    <a href="/" class="nav-logo" aria-label="JB Digital System — Página inicial">
      <span class="logo-jb">JB</span>
      <span class="logo-name">Digital System</span>
    </a>

    <nav aria-label="Navegação principal">
      <ul class="nav-links" role="list">
        {navLinks.map(link => (
          <li>
            <a href={link.href} class="nav-link">{link.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="nav-cta">
      <a href="https://jbdigitalsystem.com/signup" class="btn btn-primary">
        Quero começar
      </a>
    </div>
  </div>
</header>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(11, 29, 46, 0.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--brand-border);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding-block: 1rem;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-jb {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 0.375rem;
    background: linear-gradient(135deg, #C8A44B, #D4B06A);
    color: #0B1D2E;
    font-family: var(--brand-font-body);
    font-size: 0.75rem;
    font-weight: 700;
  }

  .logo-name {
    font-family: var(--brand-font-body);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--brand-ink);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.75rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    font-family: var(--brand-font-body);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--brand-ink-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .nav-link:hover { color: var(--brand-primary); }

  @media (max-width: 768px) {
    .nav-links { display: none; }
    .nav-cta .btn { font-size: 0.8125rem; padding: 0.5rem 1rem; }
  }
</style>
