---
import { homeFaqs } from '../../data/homeFaqs.ts';
---
<section class="faq-section" id="faq">
  <div class="section-wrap">
    <div class="section-divider" style="margin-bottom:4rem"></div>
    <h2 class="faq-title">Perguntas frequentes</h2>
    <div class="faq-list" style="max-width:680px;margin-inline:auto;">
      {homeFaqs.map(item => (
        <details>
          <summary>{item.q}</summary>
          <div class="faq-answer" set:html={item.a} />
        </details>
      ))}
    </div>
  </div>
</section>
<style>
  .faq-section { padding: 0 0 5rem; }
  .faq-title { text-align:center; font-size:clamp(1.6rem,3.5vw,2.25rem); margin-bottom:2.5rem; }
  .faq-list details { border-bottom:1px solid var(--brand-border); }
  .faq-list details:first-of-type { border-top:1px solid var(--brand-border); }
</style>
