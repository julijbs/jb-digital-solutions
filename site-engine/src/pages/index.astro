---
// ───────────────────────────────────────────────────────────────────
// Pillar page — Dra. Ana Mello (psicólogo · Calm Trust)
// Copy e dados: src/data/dra-ana-mello.ts
// Mood: calm-trust · Astro static · zero JS de runtime
// ───────────────────────────────────────────────────────────────────

import Layout from '../layouts/Layout.astro';
import { draAnaMello as client } from '../data/dra-ana-mello';
// ── Blocos — variante Calm Trust ──────────────────────────────────
import Nav from '../components/blocks/nav/NavStickyMinimal.astro';
import Hero from '../components/blocks/hero/HeroEditorialSplit.astro';
import PainPoints from '../components/blocks/painpoints/PainPointsNumbered.astro';
import About from '../components/blocks/about/AboutPortraitOffset.astro';
import Services from '../components/blocks/services/ServicesTypoList.astro';
import Process from '../components/blocks/process/ProcessHorizontalSteps.astro';
import Testimonials from '../components/blocks/testimonials/TestimonialsPullQuote.astro';
import FAQ from '../components/blocks/faq/FAQNativeDetails.astro';
import FinalCTA from '../components/blocks/finalcta/FinalCTACenteredEditorial.astro';
import Footer from '../components/blocks/footer/FooterSimpleColumns.astro';

// ── Schema JSON-LD ────────────────────────────────────────────────
const schemaObj = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": client.schemaType,
      "@id": `${client.siteUrl}/#business`,
      "name": client.businessName,
      "description": `${client.specialty}. Atende ansiedade, depressão, burnout e questões de relacionamento. Consultório em Jardins, São Paulo, e atendimento online.`,
      "url": client.siteUrl,
      "telephone": client.phone,
      "email": client.email,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Rua Haddock Lobo, 595",
        "addressLocality": client.city,
        "addressRegion": client.state,
        "postalCode": "01414-001",
        "addressCountry": "BR"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": client.lat,
        "longitude": client.lng
      },
      "openingHoursSpecification": client.openingHours.map(oh => ({
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": oh.days,
        "opens": oh.opens,
        "closes": oh.closes,
      })),
      "priceRange": client.priceRange,
      "sameAs": [`https://www.instagram.com/${client.instagram.replace('@', '')}`],
    },
    {
      "@type": "FAQPage",
      "@id": `${client.siteUrl}/#faq`,
      "mainEntity": client.copy.faqs.map(faq => ({
        "@type": "Question",
        "name": faq.question,
        "acceptedAnswer": { "@type": "Answer", "text": faq.answer },
      })),
    }
  ]
};

const title       = `Psicóloga em ${client.city} — ${client.businessName} | TCC e Terapia de Casal`;
const description = `Psicóloga clínica em Jardins, ${client.city}. Especialista em TCC, ansiedade, burnout e terapia de casal. Atendimento presencial e online. ${client.credential.split('·')[0].trim()}.`;
---

<Layout
  title={title}
  description={description}
  slug={client.slug}
  siteUrl={client.siteUrl}
  businessName={client.businessName}
  city={client.city}
  state={client.state}
  phone={client.phone}
  address={client.address}
  instagram={client.instagram}
  lat={client.lat}
  lng={client.lng}
  schemaType={client.schemaType}
  schemaJson={JSON.stringify(schemaObj)}
>
  <main id="main">

    <Nav
      businessName={client.businessName}
      phone={client.phone}
      phoneClean={client.phoneClean}
    />

    <Hero
      headline={client.copy.heroHeadline}
      subheadline={client.copy.heroSubheadline}
      credential={client.credential}
      phone={client.phone}
      phoneClean={client.phoneClean}
      photoAlt={client.copy.heroPhotoAlt}
      photoSrc={client.copy.heroPhotoSrc}
      city={client.city}
    />

    <PainPoints
      point1={client.copy.painPoints[0]}
      point2={client.copy.painPoints[1]}
      point3={client.copy.painPoints[2]}
    />

    <About
      name={client.businessName}
      headline={client.copy.aboutHeadline}
      body={client.copy.aboutBody}
      pullQuote={client.copy.aboutPullQuote}
      credential={client.copy.aboutCredential}
      photoAlt={client.copy.aboutPhotoAlt}
      photoSrc={client.copy.aboutPhotoSrc}
    />

    <Services
      headline={client.copy.servicesHeadline}
      services={client.services.map(s => ({ name: s.name, tag: s.tag, description: s.description }))}
    />

    <Process
      headline={client.copy.processHeadline}
      steps={client.copy.processSteps}
    />

    <Testimonials
      quote1={client.copy.testimonials[0].quote}
      author1={client.copy.testimonials[0].author}
      quote2={client.copy.testimonials[1].quote}
      author2={client.copy.testimonials[1].author}
    />

    <FAQ
      headline={client.copy.faqHeadline}
      faqs={client.copy.faqs}
    />

    <FinalCTA
      headline={client.copy.ctaHeadline}
      subtext={client.copy.ctaSubtext}
      buttonText={client.copy.ctaButtonText}
      phone={client.phone}
      phoneClean={client.phoneClean}
      email={client.email}
      address={client.address}
    />

    <Footer
      businessName={client.businessName}
      credential={`${client.credential.split('·')[0].trim()} · ${client.city}, ${client.state}`}
      city={client.city}
      state={client.state}
      address={client.address}
      phone={client.phone}
      email={client.email}
      instagram={client.instagram}
      year={new Date().getFullYear()}
    />

  </main>
</Layout>
