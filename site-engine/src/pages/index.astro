---
// ───────────────────────────────────────────────────────────────────
// Pillar page — orientada a dados, mood dinâmico
// Copy e dados: src/lib/activeClient.ts → src/data/<slug>.ts
// Blocos: selecionados por mood via componentsForMood()
// ───────────────────────────────────────────────────────────────────

import Layout from '../layouts/Layout.astro';
import { client } from '../lib/activeClient.ts';
import { componentsForMood } from '../lib/blockComponents.ts';

// Resolver de blocos por mood
// eslint-disable-next-line @typescript-eslint/no-explicit-any
const B = componentsForMood(client.mood) as any;

// ── Schema JSON-LD ────────────────────────────────────────────────
const schemaObj = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": client.schemaType,
      "@id": `${client.siteUrl}/#business`,
      "name": client.businessName,
      "description": client.copy.businessDescription,
      "url": client.siteUrl,
      "telephone": client.phone,
      "email": client.email,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": client.streetAddress,
        "addressLocality": client.city,
        "addressRegion": client.state,
        "postalCode": client.postalCode,
        "addressCountry": "BR"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": client.lat,
        "longitude": client.lng
      },
      "openingHoursSpecification": client.openingHours.map(oh => ({
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": oh.days,
        "opens": oh.opens,
        "closes": oh.closes,
      })),
      "priceRange": client.priceRange,
      "sameAs": [
        `https://www.instagram.com/${client.instagram.replace('@', '')}`,
        ...(client.gbpUrl ? [client.gbpUrl] : []),
      ],
    },
    {
      "@type": "FAQPage",
      "@id": `${client.siteUrl}/#faq`,
      "mainEntity": client.copy.faqs.map(faq => ({
        "@type": "Question",
        "name": faq.question,
        "acceptedAnswer": { "@type": "Answer", "text": faq.answer },
      })),
    }
  ]
};
---

<Layout
  title={client.copy.homeTitle}
  description={client.copy.homeMetaDescription}
  slug={client.slug}
  siteUrl={client.siteUrl}
  businessName={client.businessName}
  city={client.city}
  state={client.state}
  phone={client.phone}
  address={client.address}
  instagram={client.instagram}
  lat={client.lat}
  lng={client.lng}
  schemaType={client.schemaType}
  schemaJson={JSON.stringify(schemaObj)}
  mood={client.mood}
  brand={client.brand}
  logoSrc={client.logoSrc}
  ogImage={client.ogImageSrc ? `${client.siteUrl}${client.ogImageSrc}` : undefined}
>
  <main id="main">

    <B.nav
      businessName={client.businessName}
      phone={client.phone}
      phoneClean={client.phoneClean}
      logoSrc={client.logoSrc}
      ctaText={client.copy.navCtaText}
    />

    <B.hero
      headline={client.copy.heroHeadline}
      subheadline={client.copy.heroSubheadline}
      credential={client.credential}
      phone={client.phone}
      phoneClean={client.phoneClean}
      photoAlt={client.copy.heroPhotoAlt}
      photoSrc={client.copy.heroPhotoSrc}
      city={client.city}
      eyebrow={client.copy.heroEyebrow}
      ctaText={client.copy.heroCtaText}
      ctaSecondaryText={client.copy.heroCtaSecondaryText}
    />

    <B.painpoints
      point1={client.copy.painPoints[0]}
      point2={client.copy.painPoints[1]}
      point3={client.copy.painPoints[2]}
    />

    <B.about
      name={client.businessName}
      headline={client.copy.aboutHeadline}
      body={client.copy.aboutBody}
      pullQuote={client.copy.pullQuote}
      credential={client.copy.aboutCredential}
      photoAlt={client.copy.aboutPhotoAlt}
      photoSrc={client.copy.aboutPhotoSrc}
    />

    <B.services
      headline={client.copy.servicesHeadline}
      services={client.services.map(s => ({ name: s.name, tag: s.tag, description: s.description, icon: s.icon }))}
    />

    <B.process
      headline={client.copy.processHeadline}
      steps={client.copy.processSteps}
    />

    {client.copy.testimonials.length >= 2 && (
    <B.testimonials
      quote1={client.copy.testimonials[0].quote}
      author1={client.copy.testimonials[0].author}
      quote2={client.copy.testimonials[1].quote}
      author2={client.copy.testimonials[1].author}
      gbpUrl={client.gbpUrl}
    />
    )}

    <B.faq
      headline={client.copy.faqHeadline}
      faqs={client.copy.faqs}
    />

    <B.finalcta
      headline={client.copy.ctaHeadline}
      subtext={client.copy.ctaSubtext}
      buttonText={client.copy.ctaButtonText}
      phone={client.phone}
      phoneClean={client.phoneClean}
      email={client.email}
      address={client.address}
    />

    <B.footer
      businessName={client.businessName}
      credential={`${client.credential.split('·')[0].trim()} · ${client.city}, ${client.state}`}
      city={client.city}
      state={client.state}
      address={client.address}
      phone={client.phone}
      email={client.email}
      instagram={client.instagram}
      year={new Date().getFullYear()}
      logoSrc={client.logoSrc}
    />

  </main>
</Layout>
