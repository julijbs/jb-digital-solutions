---
/**
 * [servico]/[bairro].astro — SEO programático Serviço × Bairro
 *
 * Gera 1 página estática por combinação de serviço + bairro.
 * Exemplo: /terapia-individual/jardins  /nutricao-esportiva/pinheiros
 *
 * Cada página tem H1/title/meta/Schema únicos — sem duplicate content.
 * Interlink: ← pillar page (/) | → outras páginas do mesmo serviço
 *
 * A seção local-context usa data-mood para tokens de cor mood-aware.
 */

import Layout from '../../layouts/Layout.astro';
import { client } from '../../lib/activeClient.ts';
import { componentsForMood } from '../../lib/blockComponents.ts';

// Resolver de blocos (nav, hero, faq, finalcta, footer)
// eslint-disable-next-line @typescript-eslint/no-explicit-any
const B = componentsForMood(client.mood) as any;

export async function getStaticPaths() {
  // Re-importa activeClient dentro de getStaticPaths (escopo de build)
  const { client: c } = await import('../../lib/activeClient.ts');
  const paths = [];
  for (const svc of c.services) {
    for (const nbh of c.neighborhoods) {
      paths.push({
        params: { servico: svc.slug, bairro: nbh.slug },
        props: { svc, nbh },
      });
    }
  }
  return paths;
}

const { svc, nbh } = Astro.props;

// H1 e meta únicos por combinação
const h1   = svc.h1Template
  .replace('{{BAIRRO}}', nbh.name)
  .replace('{{PREP}}',   nbh.prep);
const meta = svc.metaDescTemplate
  .replace('{{BAIRRO}}', nbh.name)
  .replace('{{PREP}}',   nbh.prep);
const title = `${h1} | ${client.businessName}`;

// Canonical desta página
const canonicalUrl = `${client.siteUrl}/${svc.slug}/${nbh.slug}`;

// Schema LocalBusiness com areaServed específico por bairro
const schemaObj = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": client.schemaType,
      "@id": `${canonicalUrl}#business`,
      "name": client.businessName,
      "description": meta,
      "url": canonicalUrl,
      "telephone": client.phone,
      "email": client.email,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": client.streetAddress,
        "addressLocality": client.city,
        "addressRegion": client.state,
        "postalCode": client.postalCode,
        "addressCountry": "BR"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": client.lat,
        "longitude": client.lng
      },
      "areaServed": {
        "@type": "Place",
        "name": `${nbh.name}, ${client.city}`
      },
      "openingHoursSpecification": client.openingHours.map(oh => ({
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": oh.days,
        "opens": oh.opens,
        "closes": oh.closes,
      })),
      "priceRange": client.priceRange,
      "sameAs": [
        `https://www.instagram.com/${client.instagram.replace('@', '')}`,
        ...(client.gbpUrl ? [client.gbpUrl] : []),
      ],
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": client.businessName, "item": client.siteUrl },
        { "@type": "ListItem", "position": 2, "name": svc.name, "item": canonicalUrl },
      ]
    }
  ]
};

// FAQs filtradas: 2 mais relevantes para AEO local
const localFaqs = client.copy.faqs.slice(0, 2);

// Outros bairros do mesmo serviço (internal linking)
const otherNeighborhoods = client.neighborhoods.filter(n => n.slug !== nbh.slug);
---

<Layout
  title={title}
  description={meta}
  slug={`${svc.slug}/${nbh.slug}`}
  siteUrl={canonicalUrl}
  businessName={client.businessName}
  city={client.city}
  state={client.state}
  phone={client.phone}
  address={client.address}
  instagram={client.instagram}
  lat={client.lat}
  lng={client.lng}
  schemaType={client.schemaType}
  schemaJson={JSON.stringify(schemaObj)}
  mood={client.mood}
  brand={client.brand}
  logoSrc={client.logoSrc}
>
  <main id="main">

    <B.nav
      businessName={client.businessName}
      phone={client.phone}
      phoneClean={client.phoneClean}
      logoSrc={client.logoSrc}
      ctaText={client.copy.navCtaText}
    />

    <!-- Hero minimalista (sem foto, texto em 2 colunas — variante C para ambos os moods) -->
    <B.hero
      headline={h1}
      subheadline={`${svc.description} Atendo ${nbh.prep} ${nbh.name}, ${client.city} — presencialmente e online para todo o Brasil.`}
      credential={client.credential}
      phone={client.phone}
      phoneClean={client.phoneClean}
      city={`${nbh.name}, ${client.city}`}
      eyebrow={client.copy.heroEyebrow}
      ctaText={client.copy.heroCtaText}
      ctaSecondaryText={client.copy.heroCtaSecondaryText}
    />

    <!-- Breadcrumb + contexto local (mood-aware via data-mood) -->
    <section class="local-context" data-mood={client.mood}>
      <div class="local-context-inner">
        <nav aria-label="Localização" class="breadcrumb">
          <a href={client.siteUrl}>{client.businessName}</a>
          <span aria-hidden="true"> › </span>
          <a href={canonicalUrl}>{svc.name} {nbh.prep} {nbh.name}</a>
        </nav>

        <div class="local-intro">
          <h2 class="local-h2">{svc.name} {nbh.prep} {nbh.name}</h2>
          <p class="local-body">
            {client.copy.bairroIntroLead ?? `Se você está buscando uma ${client.specialtyNoun}`} {nbh.prep} {nbh.name} para {svc.name.toLowerCase()},
            {client.copy.bairroLocationLine ?? (client.streetAddress
              ? `o consultório da ${client.businessName} fica a poucos minutos — na ${client.streetAddress}, ${client.district}. Também ofereço atendimento online com a mesma qualidade, sem necessidade de deslocamento.`
              : `a ${client.businessName} atende toda a região de ${client.city} — presencialmente, com hora marcada, e online para todo o Brasil.`)
            }
          </p>
          <p class="local-body">
            <strong>Próximos passos:</strong> {client.copy.bairroNextSteps ?? `ligue ou envie uma mensagem para ${client.businessName}. Atendimento com hora marcada.`}
          </p>
          <a href={`tel:${client.phoneClean}`} class="btn-local-cta">
            {client.copy.bairroCtaText ?? 'Falar agora'} — {client.phone}
          </a>
        </div>

        <!-- Internal links: outros bairros do mesmo serviço -->
        <aside class="local-links" aria-label="Também atendo em">
          <p class="local-links-label">Também atendo em:</p>
          <ul class="local-links-list">
            {otherNeighborhoods.map(n => (
              <li>
                <a href={`${client.siteUrl}/${svc.slug}/${n.slug}`}>
                  {svc.name} {n.prep} {n.name}
                </a>
              </li>
            ))}
            <li>
              <a href={client.siteUrl}>← Ver todos os serviços</a>
            </li>
          </ul>
        </aside>
      </div>
    </section>

    <!-- FAQ local (2 perguntas) -->
    <B.faq
      headline={`Dúvidas sobre ${svc.name.toLowerCase()} ${nbh.prep} ${nbh.name}`}
      faqs={localFaqs}
    />

    <B.finalcta
      headline={client.copy.ctaHeadline}
      subtext={client.copy.ctaSubtext}
      buttonText={client.copy.ctaButtonText}
      phone={client.phone}
      phoneClean={client.phoneClean}
      email={client.email}
      address={client.address}
    />

    <B.footer
      businessName={client.businessName}
      credential={`${client.credential.split('·')[0].trim()} · ${client.city}, ${client.state}`}
      city={client.city}
      state={client.state}
      address={client.address}
      phone={client.phone}
      email={client.email}
      instagram={client.instagram}
      year={new Date().getFullYear()}
      logoSrc={client.logoSrc}
    />

  </main>
</Layout>

<style>
  /* ── Tokens mood-aware — bridge para --brand-* global ─────────── */
  [data-mood] {
    --lc-primary:     var(--brand-primary);
    --lc-accent:      var(--brand-accent);
    --lc-surface-alt: var(--brand-surface-alt);
    --lc-text:        var(--brand-ink);
    --lc-text-muted:  var(--brand-ink-muted);
    --lc-border:      var(--brand-border);
    --lc-font-serif:  var(--brand-font-display);
    --lc-font-sans:   var(--brand-font-body);
  }

  /* ── Local context section ───────────────────────────────────── */
  .local-context {
    background: var(--lc-surface-alt);
    padding: clamp(2.5rem, 5vw, 4rem) 1.25rem;
  }

  .local-context-inner {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* Breadcrumb */
  .breadcrumb {
    font-family: var(--lc-font-sans);
    font-size: 0.8125rem;
    color: var(--lc-text-muted);
  }
  .breadcrumb a {
    color: var(--lc-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* Intro */
  .local-intro {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .local-h2 {
    font-family: var(--lc-font-serif);
    font-size: clamp(1.375rem, 3vw, 1.875rem);
    font-weight: 700;
    color: var(--lc-primary);
    margin: 0;
  }

  .local-body {
    font-family: var(--lc-font-sans);
    font-size: 1rem;
    line-height: 1.75;
    color: var(--lc-text);
    margin: 0;
  }

  .btn-local-cta {
    display: inline-block;
    background: var(--lc-accent);
    color: #fff;
    font-family: var(--lc-font-sans);
    font-size: 0.9375rem;
    font-weight: 600;
    padding: 0.875rem 1.75rem;
    border-radius: 999px;
    text-decoration: none;
    align-self: flex-start;
    margin-top: 0.25rem;
  }
  .btn-local-cta:hover { filter: brightness(0.9); }
  .btn-local-cta:focus-visible {
    outline: 3px solid var(--lc-accent);
    outline-offset: 2px;
  }

  /* Internal links */
  .local-links {
    padding-top: 1.5rem;
    border-top: 1px solid var(--lc-border);
  }

  .local-links-label {
    font-family: var(--lc-font-sans);
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--lc-text-muted);
    margin: 0 0 0.75rem;
  }

  .local-links-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
  }

  .local-links-list a {
    font-family: var(--lc-font-sans);
    font-size: 0.875rem;
    color: var(--lc-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .local-links-list a:hover { color: var(--lc-accent); }
</style>
