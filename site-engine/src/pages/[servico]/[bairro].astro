---
/**
 * [servico]/[bairro].astro — SEO programático Serviço × Bairro
 *
 * Gera 1 página estática para cada combinação de serviço + bairro.
 * Exemplo: /terapia-individual/jardins  /terapia-casal/pinheiros
 *
 * Cada página tem H1/title/meta/Schema únicos — sem duplicate content.
 * Interlink: ← pillar page (/) | → outras páginas do mesmo serviço
 */

import Layout from '../../layouts/Layout.astro';
import { draAnaMello as client } from '../../data/dra-ana-mello';
// Blocos Calm Trust (herdam o design da pillar page)
import Nav from '../../components/blocks/nav/NavStickyMinimal.astro';
import Hero from '../../components/blocks/hero/HeroMinimalistText.astro';
import FAQ from '../../components/blocks/faq/FAQNativeDetails.astro';
import FinalCTA from '../../components/blocks/finalcta/FinalCTACenteredEditorial.astro';
import Footer from '../../components/blocks/footer/FooterSimpleColumns.astro';

export async function getStaticPaths() {
  const paths = [];
  for (const svc of client.services) {
    for (const nbh of client.neighborhoods) {
      paths.push({
        params: { servico: svc.slug, bairro: nbh.slug },
        props: { svc, nbh },
      });
    }
  }
  return paths;
}

const { svc, nbh } = Astro.props;

// H1 e meta únicos por combinação
const h1    = svc.h1Template
  .replace('{{BAIRRO}}', nbh.name)
  .replace('{{PREP}}', nbh.prep);
const meta  = svc.metaDescTemplate
  .replace('{{BAIRRO}}', nbh.name)
  .replace('{{PREP}}', nbh.prep);
const title = `${h1} | ${client.businessName}`;

// Canonical desta página
const canonicalUrl = `${client.siteUrl}/${svc.slug}/${nbh.slug}`;

// Schema LocalBusiness com areaServed específico por bairro
const schemaObj = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": client.schemaType,
      "@id": `${canonicalUrl}#business`,
      "name": client.businessName,
      "description": meta,
      "url": canonicalUrl,
      "telephone": client.phone,
      "email": client.email,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Rua Haddock Lobo, 595",
        "addressLocality": client.city,
        "addressRegion": client.state,
        "postalCode": "01414-001",
        "addressCountry": "BR"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": client.lat,
        "longitude": client.lng
      },
      "areaServed": {
        "@type": "Place",
        "name": `${nbh.name}, ${client.city}`
      },
      "openingHoursSpecification": client.openingHours.map(oh => ({
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": oh.days,
        "opens": oh.opens,
        "closes": oh.closes,
      })),
      "priceRange": client.priceRange,
      "sameAs": [`https://www.instagram.com/${client.instagram.replace('@', '')}`],
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": client.businessName, "item": client.siteUrl },
        { "@type": "ListItem", "position": 2, "name": svc.name, "item": `${client.siteUrl}/${svc.slug}/${nbh.slug}` },
      ]
    }
  ]
};

// FAQs filtradas: 2 mais relevantes para este serviço
// Usa as 2 primeiras da lista geral (suficiente para AEO local)
const localFaqs = client.copy.faqs.slice(0, 2);

// Outros bairros do mesmo serviço (para internal linking)
const otherNeighborhoods = client.neighborhoods.filter(n => n.slug !== nbh.slug);
---

<Layout
  title={title}
  description={meta}
  slug={`${svc.slug}/${nbh.slug}`}
  siteUrl={canonicalUrl}
  businessName={client.businessName}
  city={client.city}
  state={client.state}
  phone={client.phone}
  address={client.address}
  instagram={client.instagram}
  lat={client.lat}
  lng={client.lng}
  schemaType={client.schemaType}
  schemaJson={JSON.stringify(schemaObj)}
>
  <main id="main">

    <Nav
      businessName={client.businessName}
      phone={client.phone}
      phoneClean={client.phoneClean}
    />

    <!-- Hero minimalista (sem foto, texto em 2 colunas) -->
    <Hero
      headline={h1}
      subheadline={`${svc.description} Atendo ${nbh.prep} ${nbh.name}, São Paulo — presencialmente e online para todo o Brasil.`}
      credential={client.credential}
      phone={client.phone}
      phoneClean={client.phoneClean}
      city={`${nbh.name}, ${client.city}`}
    />

    <!-- Breadcrumb + contexto local -->
    <section class="local-context">
      <div class="local-context-inner">
        <nav aria-label="Localização" class="breadcrumb">
          <a href={client.siteUrl}>{client.businessName}</a>
          <span aria-hidden="true"> › </span>
          <a href={`${client.siteUrl}/${svc.slug}/${nbh.slug}`}>{svc.name} {nbh.prep} {nbh.name}</a>
        </nav>

        <div class="local-intro">
          <h2 class="local-h2">{svc.name} {nbh.prep} {nbh.name}</h2>
          <p class="local-body">
            Se você está buscando uma psicóloga {nbh.prep} {nbh.name} para {svc.name.toLowerCase()},
            o consultório da {client.businessName} fica a poucos minutos — na Rua Haddock Lobo, 595, Jardins.
            Também ofereço atendimento online com a mesma qualidade, sem necessidade de deslocamento.
          </p>
          <p class="local-body">
            <strong>Próximos passos:</strong> ligue ou envie uma mensagem para agendar sua primeira conversa.
            50 minutos, sem compromisso de continuidade se não fizer sentido.
          </p>
          <a href={`tel:${client.phoneClean}`} class="btn-local-cta">
            Agendar conversa — {client.phone}
          </a>
        </div>

        <!-- Internal links: outros bairros do mesmo serviço -->
        <aside class="local-links" aria-label="Também atendo em">
          <p class="local-links-label">Também atendo em:</p>
          <ul class="local-links-list">
            {otherNeighborhoods.map(n => (
              <li>
                <a href={`${client.siteUrl}/${svc.slug}/${n.slug}`}>
                  {svc.name} {n.prep} {n.name}
                </a>
              </li>
            ))}
            <li>
              <a href={client.siteUrl}>← Ver todos os serviços</a>
            </li>
          </ul>
        </aside>
      </div>
    </section>

    <!-- FAQ local (2 perguntas + Schema FAQPage) -->
    <FAQ
      headline={`Dúvidas sobre ${svc.name.toLowerCase()} ${nbh.prep} ${nbh.name}`}
      faqs={localFaqs}
    />

    <FinalCTA
      headline={client.copy.ctaHeadline}
      subtext={client.copy.ctaSubtext}
      buttonText={client.copy.ctaButtonText}
      phone={client.phone}
      phoneClean={client.phoneClean}
      email={client.email}
      address={client.address}
    />

    <Footer
      businessName={client.businessName}
      credential={`${client.credential.split('·')[0].trim()} · ${client.city}, ${client.state}`}
      city={client.city}
      state={client.state}
      address={client.address}
      phone={client.phone}
      email={client.email}
      instagram={client.instagram}
      year={new Date().getFullYear()}
    />

  </main>
</Layout>

<style>
  /* ── Local context section ──────────────────────────────────── */
  .local-context {
    --ct-primary: #3E5C76;
    --ct-accent: #C08552;
    --ct-surface: #F4F2ED;
    --ct-surface-alt: #EAE6DE;
    --ct-text: #1A1A1A;
    --ct-text-muted: #5A6475;
    --ct-border: #D4CFC8;
    background: var(--ct-surface-alt);
    padding: clamp(2.5rem, 5vw, 4rem) 1.25rem;
  }

  .local-context-inner {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* Breadcrumb */
  .breadcrumb {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.8125rem;
    color: var(--ct-text-muted);
  }
  .breadcrumb a {
    color: var(--ct-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* Intro */
  .local-intro {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .local-h2 {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1.375rem, 3vw, 1.875rem);
    font-weight: 700;
    color: var(--ct-primary);
    margin: 0;
  }

  .local-body {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 1rem;
    line-height: 1.75;
    color: var(--ct-text);
    margin: 0;
  }

  .btn-local-cta {
    display: inline-block;
    background: var(--ct-accent);
    color: #fff;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.9375rem;
    font-weight: 600;
    padding: 0.875rem 1.75rem;
    border-radius: 999px;
    text-decoration: none;
    align-self: flex-start;
    margin-top: 0.25rem;
  }
  .btn-local-cta:hover { filter: brightness(0.9); }
  .btn-local-cta:focus-visible {
    outline: 3px solid var(--ct-accent);
    outline-offset: 2px;
  }

  /* Internal links */
  .local-links {
    padding-top: 1.5rem;
    border-top: 1px solid var(--ct-border);
  }

  .local-links-label {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--ct-text-muted);
    margin: 0 0 0.75rem;
  }

  .local-links-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
  }

  .local-links-list a {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.875rem;
    color: var(--ct-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .local-links-list a:hover { color: var(--ct-accent); }
</style>
