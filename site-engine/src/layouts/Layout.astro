---
import '../styles/global.css';
import type { BrandTokens } from '../lib/types.ts';

export interface Props {
  title:        string;
  description:  string;
  slug:         string;
  siteUrl:      string;
  businessName: string;
  city:         string;
  state:        string;
  phone:        string;
  address:      string;
  instagram?:   string;
  lat?:         string;
  lng?:         string;
  schemaType:   string;
  schemaJson:   string;
  ogImage?:     string;
  /** Mood do cliente — controla qual família de fontes carregar */
  mood?:        string;
  /** Tokens de marca derivados do logotipo — sobrepõem os defaults do :root */
  brand?:    BrandTokens;
  /** Caminho para o logo usado no favicon e og:image */
  logoSrc?:  string;
}

const {
  title, description, slug, siteUrl, businessName,
  city, state, phone, address, instagram,
  lat, lng, schemaType, schemaJson,
  ogImage: ogImageProp,
  mood = 'calm-trust',
  brand, logoSrc,
} = Astro.props;

// Fallback: logo do cliente (sempre existe), evita og:image 404 quando og-default.png não existe
// Usa URL().origin para garantir domínio raiz mesmo quando siteUrl é o canonical de uma subpágina
const rootUrl = new URL(siteUrl).origin;
const ogImage = ogImageProp ?? (logoSrc ? `${rootUrl}${logoSrc}` : `${rootUrl}/og-default.png`);

const canonical = siteUrl;
const stateCode = state.toUpperCase().slice(0, 2);

// URLs das fontes por mood (display=swap previne CLS)
const fontHref = brand?.googleFontsUrl ?? (mood === 'fresh-clinical'
  ? 'https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&display=swap'
  : 'https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;0,9..144,800;1,9..144,400;1,9..144,600&family=Inter:wght@400;500;600&display=swap');
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- ── Title & description ── -->
  <title>{title}</title>
  <meta name="description" content={description} />

  <!-- ── Canonical ── -->
  <link rel="canonical" href={canonical} />

  <!-- ── Robots ── -->
  <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />

  <!-- ── Geo (SEO local) ── -->
  <meta name="geo.region" content={`BR-${stateCode}`} />
  <meta name="geo.placename" content={city} />
  {lat && lng && (
    <>
      <meta name="geo.position" content={`${lat};${lng}`} />
      <meta name="ICBM" content={`${lat}, ${lng}`} />
    </>
  )}

  <!-- ── Open Graph ── -->
  <meta property="og:type"        content="website" />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url"         content={canonical} />
  <meta property="og:site_name"   content={businessName} />
  <meta property="og:locale"      content="pt_BR" />
  <meta property="og:image"       content={ogImage} />
  <meta property="og:image:width"  content="1200" />
  <meta property="og:image:height" content="630" />

  <!-- ── Twitter Card ── -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImage} />

  {brand && (
    <style set:html={`
      :root {
        --brand-primary: ${brand.primary};
        --brand-primary-dark: ${brand.primaryDark};
        --brand-primary-light: ${brand.primaryLight};
        --brand-accent: ${brand.accent};
        --brand-accent-dark: ${brand.accentDark};
        --brand-accent-light: ${brand.accentLight};
        --brand-surface: ${brand.surface};
        --brand-surface-muted: ${brand.surfaceMuted};
        --brand-surface-dark: ${brand.surfaceDark};
        --brand-surface-alt: ${brand.surfaceAlt};
        --brand-ink: ${brand.ink};
        --brand-ink-muted: ${brand.inkMuted};
        --brand-ink-faint: ${brand.inkFaint};
        --brand-border: ${brand.border};
        --brand-break: ${brand.breakBg};
        --brand-white: ${brand.white};
        --brand-font-display: ${brand.fontDisplayFamily};
        --brand-font-body: ${brand.fontBodyFamily};
      }
    `} />
  )}

  <!-- ── Preconnect (performance) ── -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <!-- ── Fonts: carrega família correta por mood ── -->
  <link rel="stylesheet" href={fontHref} />

  <!-- ── Schema JSON-LD ── -->
  <script type="application/ld+json" set:html={schemaJson}></script>

  <!-- ── Favicon (placeholder) ── -->
  <link rel="icon" type={logoSrc?.endsWith('.png') ? 'image/png' : 'image/svg+xml'} href={logoSrc ?? '/favicon.svg'} />
</head>
<body>
  <a href="#main" class="skip-link">Pular para o conteúdo</a>

  <slot />

</body>
</html>
