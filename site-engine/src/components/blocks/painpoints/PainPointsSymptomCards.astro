---
/**
 * PainPointsSymptomCards — Variante B · Fresh Clinical
 * Layout: 3 cards em grid com ícone SVG orgânico + título curto + texto.
 * Contraste com PainPointsNumbered: visual vs. tipográfico; cards vs. lista.
 * Regras: zero JS · WCAG AA · hand-CSS
 */
export interface Props {
  sectionLabel?: string;
  /** Máximo 3 cards */
  cards: { icon: 'energy' | 'cycle' | 'weight' | 'gut' | 'anxiety' | 'sleep'; title: string; body: string }[];
}

const { sectionLabel = 'Para quem é o meu trabalho?', cards } = Astro.props;

// SVGs orgânicos simples (sem dependência externa)
const icons: Record<string, string> = {
  energy: `<svg viewBox="0 0 40 40" fill="none" aria-hidden="true"><circle cx="20" cy="20" r="18" stroke="currentColor" stroke-width="1.5"/><path d="M22 10l-6 12h8l-6 12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  cycle:  `<svg viewBox="0 0 40 40" fill="none" aria-hidden="true"><circle cx="20" cy="20" r="18" stroke="currentColor" stroke-width="1.5"/><path d="M13 20a7 7 0 0114 0" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/><path d="M27 20a7 7 0 01-14 0" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-dasharray="3 3"/><path d="M25 17l2 3-3 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  weight: `<svg viewBox="0 0 40 40" fill="none" aria-hidden="true"><circle cx="20" cy="20" r="18" stroke="currentColor" stroke-width="1.5"/><path d="M12 26h16M14 26V20m4 6v-8m4 8v-5m4 5V18" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/></svg>`,
  gut:    `<svg viewBox="0 0 40 40" fill="none" aria-hidden="true"><circle cx="20" cy="20" r="18" stroke="currentColor" stroke-width="1.5"/><path d="M15 15c0 0 3 2 3 5s-3 5-3 5 3 2 3 5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/><path d="M25 15c0 0-3 2-3 5s3 5 3 5-3 2-3 5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/></svg>`,
  anxiety:`<svg viewBox="0 0 40 40" fill="none" aria-hidden="true"><circle cx="20" cy="20" r="18" stroke="currentColor" stroke-width="1.5"/><path d="M20 13v9" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><circle cx="20" cy="26" r="1.5" fill="currentColor"/></svg>`,
  sleep:  `<svg viewBox="0 0 40 40" fill="none" aria-hidden="true"><circle cx="20" cy="20" r="18" stroke="currentColor" stroke-width="1.5"/><path d="M16 14a8 8 0 100 12 6 6 0 010-12z" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/></svg>`,
};
---

<section class="pp-cards" aria-labelledby="pp-cards-heading">
  <div class="pp-cards-inner">

    <h2 id="pp-cards-heading" class="pp-cards-heading">{sectionLabel}</h2>

    <ul class="pp-grid" role="list">
      {cards.slice(0, 3).map((card) => (
        <li class="pp-card">
          <span class="pp-icon" set:html={icons[card.icon] ?? icons.energy} />
          <h3 class="pp-card-title">{card.title}</h3>
          <p class="pp-card-body">{card.body}</p>
        </li>
      ))}
    </ul>

    <p class="pp-footer-line">
      Se você se identificou com qualquer um desses cenários, você está no lugar certo.
    </p>

  </div>
</section>

<style>
  .pp-cards {
    --fc-primary: #2D6A4F;
    --fc-accent: #52B788;
    --fc-surface-alt: #EAF2EE;
    --fc-border: #C8DDD1;
    --fc-text: #1A2318;
    --fc-text-muted: #4A6358;
    background: var(--fc-surface-alt);
    padding: clamp(3rem, 6vw, 5rem) 1.25rem;
  }

  .pp-cards-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.5rem;
  }

  .pp-cards-heading {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: clamp(1.5rem, 3vw, 2.125rem);
    font-weight: 400;
    color: var(--fc-primary);
    margin: 0;
    text-align: center;
  }

  .pp-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    width: 100%;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .pp-card {
    background: #fff;
    border: 1px solid var(--fc-border);
    border-radius: 8px;
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .pp-icon {
    display: block;
    width: 40px;
    height: 40px;
    color: var(--fc-accent);
    flex-shrink: 0;
  }

  .pp-card-title {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: 1.1875rem;
    font-weight: 400;
    color: var(--fc-primary);
    margin: 0;
    line-height: 1.3;
  }

  .pp-card-body {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--fc-text);
    margin: 0;
  }

  .pp-footer-line {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 0.9375rem;
    font-style: italic;
    color: var(--fc-text-muted);
    margin: 0;
    text-align: center;
  }

  @media (max-width: 640px) {
    .pp-grid { grid-template-columns: 1fr; }
  }
</style>
