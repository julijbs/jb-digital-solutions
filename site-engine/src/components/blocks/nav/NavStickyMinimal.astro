---
export interface Props {
  businessName: string;
  phone:        string;
  phoneClean:   string;
  /**
   * Caminho do logotipo (relativo a /public). Quando presente,
   * exibe a imagem no lugar do nome em texto.
   * Convenção: /public/<slug>/logo.svg
   */
  logoSrc?:     string;
  /** Texto do CTA do menu. Default: "Falar no WhatsApp". */
  ctaText?:     string;
}
const { businessName, phone, phoneClean, logoSrc, ctaText = 'Falar no WhatsApp' } = Astro.props;
---

<header role="banner" class="nav-bar">
  <div class="section-wrap nav-inner">
    <a href="#hero" class="nav-logo" aria-label={`${businessName} — início`}>
      {logoSrc
        ? <img src={logoSrc} alt={businessName} class="nav-logo-img" width="160" height="40" decoding="async" />
        : businessName
      }
    </a>
    <nav role="navigation" aria-label="Menu principal">
      <ul class="nav-links">
        <li><a href="#sobre">Sobre</a></li>
        <li><a href="#servicos">Serviços</a></li>
        <li><a href="#faq">FAQ</a></li>
      </ul>
    </nav>
    <a
      href={`https://wa.me/55${phoneClean}`}
      class="btn btn-primary nav-cta"
      aria-label={ctaText.includes('WhatsApp') ? `${ctaText} — ${phone}` : `${ctaText} via WhatsApp — ${phone}`}
      target="_blank"
      rel="noopener noreferrer"
    >
      {ctaText}
    </a>
  </div>
</header>

<style>
  .nav-bar {
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--brand-surface) 92%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--brand-surface-dark);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 1rem;
    gap: 1.5rem;
  }
  .nav-logo {
    font-family: var(--brand-font-display);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--brand-ink);
    white-space: nowrap;
    text-decoration: none;
  }
  .nav-logo-img {
    display: block;
    height: 2rem;
    width: auto;
    max-width: 160px;
    object-fit: contain;
  }
  .nav-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 2rem;
  }
  .nav-links a {
    font-size: 0.9375rem;
    color: var(--brand-ink-muted);
    text-decoration: none;
    transition: color 0.15s;
  }
  .nav-links a:hover { color: var(--brand-ink); }

  @media (max-width: 640px) {
    .nav-links { display: none; }
    .nav-cta { padding: 0.625rem 1.125rem; font-size: 0.875rem; }
  }
</style>
