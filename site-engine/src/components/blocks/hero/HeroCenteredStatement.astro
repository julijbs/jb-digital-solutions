---
/**
 * HeroCenteredStatement — Variante B · Fresh Clinical (nutricionista/saúde)
 * Layout: headline centralizada, foto abaixo em forma oval, CTAs empilhados.
 * Mood: Fresh Clinical (#2D6A4F, #52B788, #F7F9F7, DM Serif + DM Sans)
 * Regras: zero JS · WCAG AA · Lighthouse-tuned · hand-CSS
 */
export interface Props {
  headline: string;
  subheadline: string;
  credential: string;
  phone: string;
  phoneClean: string;
  photoAlt: string;
  photoSrc?: string;
  city: string;
}

const { headline, subheadline, credential, phone, phoneClean, photoAlt, photoSrc, city } = Astro.props;
---

<section class="hero-cs" aria-label="Apresentação">
  <div class="hero-cs-inner">

    <p class="hero-cs-tag" aria-hidden="true">Nutricionista · {city}</p>

    <h1 class="hero-cs-headline">{headline}</h1>

    <p class="hero-cs-sub">{subheadline}</p>

    <p class="hero-cs-cred">{credential}</p>

    <div class="hero-cs-actions">
      <a href={`tel:${phoneClean}`} class="btn-primary-fc">
        Agendar consulta
      </a>
      <a href="#servicos" class="btn-ghost-fc">
        Ver como funciona
      </a>
    </div>

    <!-- Foto oval — placeholder visível se photoSrc ausente -->
    <div class="hero-cs-photo-wrap" aria-hidden={!photoSrc}>
      {photoSrc
        ? <img src={photoSrc} alt={photoAlt} class="hero-cs-photo" width="400" height="480" loading="eager" decoding="async" />
        : <div class="hero-cs-photo-placeholder" role="img" aria-label={photoAlt}>
            <span>Foto profissional</span>
          </div>
      }
    </div>

    <p class="hero-cs-phone-inline">
      Ou ligue: <a href={`tel:${phoneClean}`}>{phone}</a>
    </p>

  </div>
</section>

<style>
  /* ── Fresh Clinical tokens ─────────────────────────────────── */
  .hero-cs {
    --fc-primary: #2D6A4F;
    --fc-accent: #52B788;
    --fc-surface: #F7F9F7;
    --fc-text: #1A2318;
    --fc-text-muted: #4A6358;
    --fc-border: #C8DDD1;
    background: var(--fc-surface);
    padding: clamp(3rem, 6vw, 5rem) 1.25rem clamp(2rem, 4vw, 3rem);
    text-align: center;
  }

  .hero-cs-inner {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  /* Tag */
  .hero-cs-tag {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--fc-accent);
    margin: 0;
  }

  /* Headline */
  .hero-cs-headline {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 400;
    line-height: 1.15;
    color: var(--fc-primary);
    margin: 0;
    max-width: 640px;
  }

  /* Subheadline */
  .hero-cs-sub {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--fc-text);
    margin: 0;
    max-width: 560px;
  }

  /* Credencial */
  .hero-cs-cred {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 0.8125rem;
    color: var(--fc-text-muted);
    margin: 0;
    letter-spacing: 0.02em;
  }

  /* CTAs */
  .hero-cs-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    margin-top: 0.25rem;
  }

  .btn-primary-fc {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--fc-accent);
    color: #fff;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 0.9375rem;
    font-weight: 600;
    padding: 0.875rem 2rem;
    border-radius: 999px;
    text-decoration: none;
    transition: background 0.15s ease;
  }
  .btn-primary-fc:hover { background: #3ea06a; }
  .btn-primary-fc:focus-visible {
    outline: 3px solid var(--fc-accent);
    outline-offset: 2px;
  }

  .btn-ghost-fc {
    display: inline-flex;
    align-items: center;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--fc-primary);
    text-decoration: underline;
    text-underline-offset: 3px;
    padding: 0.875rem 0.5rem;
  }
  .btn-ghost-fc:hover { color: var(--fc-accent); }

  /* Foto oval */
  .hero-cs-photo-wrap {
    margin-top: 0.5rem;
    width: 260px;
    height: 320px;
    border-radius: 50% / 40%;
    overflow: hidden;
    border: 4px solid var(--fc-border);
  }

  .hero-cs-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
  }

  .hero-cs-photo-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--fc-surface);
    border: 2px dashed var(--fc-border);
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 0.8125rem;
    color: var(--fc-text-muted);
  }

  /* Telefone inline */
  .hero-cs-phone-inline {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 0.875rem;
    color: var(--fc-text-muted);
    margin: 0;
  }
  .hero-cs-phone-inline a {
    color: var(--fc-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
    font-weight: 500;
  }

  /* Fontes DM Serif Display + DM Sans são carregadas pelo Layout.astro (mood: fresh-clinical) */
</style>
