---
// Testimonials — Variante A: Pull quote + depoimento secundário
// Anti cara-de-IA: não são 3 cards iguais com estrelas. Uma aspas grande, texto fluido.
export interface Props {
  quote1:   string;
  author1:  string;
  quote2?:  string;
  author2?: string;
  gbpUrl?:  string;
}
const { quote1, author1, quote2, author2, gbpUrl } = Astro.props;
---

<section id="depoimentos" aria-labelledby="testimonials-headline" class="testimonials-section">
  <div class="section-wrap">

    <span class="section-label">O que dizem os pacientes</span>

    <!-- Depoimento principal — pull quote style -->
    <figure class="primary-quote" aria-labelledby="testimonials-headline">
      <span class="quote-mark" aria-hidden="true">"</span>
      <blockquote>
        <p id="testimonials-headline">{quote1}</p>
      </blockquote>
      <figcaption class="quote-author">— {author1}</figcaption>
    </figure>

    <!-- Divisor + depoimento secundário (opcional) -->
    {quote2 && (
      <div class="secondary-block">
        <div class="secondary-divider" aria-hidden="true"></div>
        <figure class="secondary-quote">
          <blockquote>
            <p>"{quote2}"</p>
          </blockquote>
          <figcaption class="quote-author secondary-author">— {author2}</figcaption>
        </figure>
      </div>
    )}

    {gbpUrl && (
      <a href={gbpUrl} target="_blank" rel="noopener noreferrer" class="gbp-badge" aria-label="Ver avaliações no Google">
        <svg class="gbp-logo" viewBox="0 0 24 24" aria-hidden="true" width="20" height="20"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
        <span class="gbp-text">
          <span class="gbp-stars" aria-label="5 estrelas">★★★★★</span>
          <span class="gbp-label">Ver avaliações no Google</span>
        </span>
      </a>
    )}

  </div>
</section>

<style>
  .testimonials-section {
    padding-block: 6.5rem;
    background: var(--brand-primary);
    color: #fff;
  }

  .testimonials-section .section-label {
    color: rgba(255,255,255,0.55);
  }

  /* ── Primary quote ── */
  .primary-quote {
    margin: 0 0 4rem;
    position: relative;
    max-width: 760px;
  }

  .quote-mark {
    font-family: var(--brand-font-display);
    font-size: 7rem;
    line-height: 0.7;
    color: var(--brand-accent);
    display: block;
    margin-bottom: 1rem;
    opacity: 0.7;
    user-select: none;
  }

  .primary-quote blockquote p {
    font-family: var(--brand-font-display);
    font-size: clamp(1.375rem, 2.5vw, 1.875rem);
    font-style: italic;
    font-weight: 400;
    line-height: 1.5;
    color: rgba(255,255,255,0.95);
    margin: 0;
  }

  .quote-author {
    margin-top: 1.25rem;
    font-size: 0.875rem;
    color: rgba(255,255,255,0.55);
    font-style: normal;
    letter-spacing: 0.02em;
  }

  /* ── Secondary ── */
  .secondary-block {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: 2rem;
    align-items: start;
    max-width: 560px;
  }

  .secondary-divider {
    width: 1px;
    height: 100%;
    min-height: 80px;
    background: var(--brand-accent);
    opacity: 0.45;
    margin-top: 0.25rem;
  }

  .secondary-quote blockquote p {
    font-size: 1rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.75);
    margin: 0;
    font-style: italic;
  }

  .secondary-author {
    margin-top: 0.75rem;
    font-size: 0.8125rem;
  }

  /* ── Google badge ── */
  .gbp-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 3rem;
    padding: 0.75rem 1.25rem;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.2s;
  }
  .gbp-badge:hover { background: rgba(255,255,255,0.15); }
  .gbp-text { display: flex; flex-direction: column; gap: 0.1rem; }
  .gbp-stars { color: #FBBC05; font-size: 1rem; letter-spacing: 0.05em; }
  .gbp-label { font-size: 0.8125rem; color: rgba(255,255,255,0.8); }

  @media (max-width: 640px) {
    .testimonials-section { padding-block: 4rem; }
    .quote-mark { font-size: 5rem; }
    .secondary-block { grid-template-columns: 1fr; }
    .secondary-divider { height: 1px; width: 3rem; min-height: auto; }
  }
</style>
