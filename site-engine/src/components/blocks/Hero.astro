---
// Hero — Variante A: Editorial Split
// Layout assimétrico: texto à esquerda (55%), foto à direita (45%)
// Estética: creme quente, Fraunces serif, sem gradiente escuro, sem glassmorphism
export interface Props {
  headline:    string;  // max 60 chars
  subheadline: string;  // 1-2 frases, contexto + público
  credential:  string;  // ex: "CRP 06/12345 · São Paulo, SP"
  phone:       string;
  phoneClean:  string;
  photoAlt:    string;
  photoSrc?:   string;  // URL da foto real; se vazio, mostra placeholder
  city:        string;
}
const { headline, subheadline, credential, phone, phoneClean, photoAlt, photoSrc, city } = Astro.props;
---

<section id="hero" aria-labelledby="hero-headline" class="hero-section">
  <div class="section-wrap hero-grid">

    <!-- ── Coluna esquerda: copy ── -->
    <div class="hero-copy">

      <span class="section-label">Psicologia Clínica · {city}</span>

      <h1 id="hero-headline" class="hero-headline">
        {headline}
      </h1>

      <p class="hero-sub">{subheadline}</p>

      <div class="hero-actions">
        <a
          href={`https://wa.me/55${phoneClean}`}
          class="btn btn-primary"
          aria-label={`Agendar sessão via WhatsApp — ${phone}`}
          target="_blank"
          rel="noopener noreferrer"
        >
          <!-- WhatsApp icon inline SVG -->
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Agendar sessão
        </a>
        <span class="hero-phone">
          <a href={`tel:+55${phoneClean}`} aria-label={`Ligar para ${phone}`}>{phone}</a>
        </span>
      </div>

      <p class="hero-credential" aria-label="Registro profissional">{credential}</p>
    </div>

    <!-- ── Coluna direita: foto ── -->
    <div class="hero-photo-wrap" aria-hidden={!photoSrc}>
      <div class="photo-frame hero-photo">
        {photoSrc
          ? <img src={photoSrc} alt={photoAlt} width="480" height="640" loading="eager" fetchpriority="high" />
          : <div class="photo-hint" role="img" aria-label={`Foto de ${photoAlt}`}>
              Foto da profissional<br /><span style="opacity:.55;font-size:.75rem">3:4 — retrato</span>
            </div>
        }
      </div>
    </div>

  </div>
</section>

<style>
  .hero-section {
    padding-block: 5rem 5.5rem;
    background: #F4F2ED;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 55fr 45fr;
    gap: 4rem;
    align-items: center;
  }
  .hero-copy { max-width: 600px; }

  .hero-headline {
    font-family: 'Fraunces', serif;
    font-size: clamp(2.5rem, 5.5vw, 4.25rem);
    font-weight: 700;
    line-height: 1.08;
    color: #1E2733;
    margin: 0 0 1.5rem;
    /* Hanging indent for the em-dash if present */
  }

  .hero-sub {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: #5A6475;
    margin: 0 0 2.25rem;
    max-width: 480px;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 1.75rem;
  }

  .hero-phone a {
    font-size: 0.9375rem;
    color: #3E5C76;
    text-decoration: none;
    border-bottom: 1px solid #C08552;
    padding-bottom: 1px;
  }
  .hero-phone a:hover { color: #2F4A60; }

  .hero-credential {
    font-size: 0.8125rem;
    color: #5A6475; /* contraste WCAG AA: ~5.1:1 em fundo creme */
    margin: 0;
    letter-spacing: 0.02em;
  }

  /* ── Photo ── */
  .hero-photo-wrap { display: flex; justify-content: flex-end; }
  .hero-photo {
    width: 100%;
    max-width: 420px;
    aspect-ratio: 3 / 4;
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .hero-section { padding-block: 3.5rem 4rem; }
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .hero-photo-wrap { justify-content: center; }
    .hero-photo { max-width: 300px; }
    .hero-copy { max-width: 100%; }
  }
</style>
